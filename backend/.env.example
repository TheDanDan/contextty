# Required — Gemini API key (never exposed to the client)
GEMINI_API_KEY=AIza...

# Required — Firebase service account JSON (paste the full JSON as a single line)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}

# Required — Upstash Redis URL (TLS, format: rediss://default:PASSWORD@HOST.upstash.io:6380)
UPSTASH_REDIS_URL=rediss://default:password@region-host.upstash.io:6380

# Comma-separated list of allowed frontend origins (no trailing slashes)
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend-domain.com

# Server port (Cloud Run injects PORT=8080 automatically)
PORT=8080

# Trial limits (defaults shown)
TRIAL_COST_LIMIT=0.05
TRIAL_TTL_SECONDS=86400
